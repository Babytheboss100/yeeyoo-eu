# ═══════════════════════════════════════════════════════════════
# Yeeyoo EU Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════

PORT=3001
NODE_ENV=development

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://user:pass@localhost:5432/yeeyoo_eu

# JWT Auth
JWT_SECRET=your-jwt-secret-change-this

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# Invite-only mode (set to 'false' to disable)
INVITE_ONLY=true

# ─── AI API Keys ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
OPENAI_API_KEY=sk-...
GROK_API_KEY=xai-...
DEEPSEEK_API_KEY=sk-...

# ─── Google OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ─── Stripe Billing ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_VEKST=price_...
STRIPE_PRICE_BEDRIFT=price_...

# ─── SendGrid Email ──────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=no-reply@yeeyoo.eu
